@implements IDisposable
@inject VelopackUpdateService UpdateService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">NexusLocal</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="quote">
                <span class="bi bi-file-earmark-text-fill-nav-menu" aria-hidden="true"></span> Quote
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link nav-link-menu" href="settings">
                <span>
                    <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span> Settings
                </span>
                @if (_showSettingsBadge)
                {
                    <span class="badge rounded-pill text-bg-warning nav-badge">?</span>
                }
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool _showSettingsBadge;

    protected override async Task OnInitializedAsync()
    {
        UpdateService.SnapshotChanged += HandleSnapshotChanged;
        ApplySnapshot(UpdateService.GetSnapshot());
        await UpdateService.EnsureStartupCheckAsync();
        ApplySnapshot(UpdateService.GetSnapshot());
    }

    private void HandleSnapshotChanged()
    {
        ApplySnapshot(UpdateService.GetSnapshot());
        _ = InvokeAsync(StateHasChanged);
    }

    private void ApplySnapshot(VelopackAppSnapshot snapshot)
    {
        _showSettingsBadge = snapshot.IsUpdateAvailable;
    }

    public void Dispose()
    {
        UpdateService.SnapshotChanged -= HandleSnapshotChanged;
    }
}
