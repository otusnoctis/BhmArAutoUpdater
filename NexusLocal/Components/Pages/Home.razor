@page "/"
@inject VelopackUpdateService UpdateService

<PageTitle>NexusLocal</PageTitle>

<div class="hero">
  <div class="hero__header">
    <div>
    <h1>NexusLocal</h1>
      <p>Spike minimo de MAUI Blazor Hybrid sobre Velopack.</p>
    </div>
    @if (_snapshot?.IsDevMode == true)
    {
      <span class="hero__chip hero__chip--danger">dev mode</span>
    }
  </div>

  @if (_snapshot is not null)
  {
    <div class="hero__grid">
      <section class="hero__card">
        <h2>App</h2>
        <p class="hero__value">@_snapshot.AppVersion</p>
      </section>
      <section class="hero__card">
        <h2>Velopack</h2>
        <p class="hero__value">@_snapshot.VelopackVersion</p>
      </section>
    </div>

    <section class="hero__update @(GetUpdatePanelClass())">
      <div class="hero__update-copy">
        <p class="hero__eyebrow">Actualizaciones</p>
        <h2>@GetUpdateHeadline()</h2>
        <p>@_snapshot.UpdateMessage</p>
        @if (_snapshot.LastCheckedAt is not null)
        {
          <p class="hero__meta">Ultima comprobacion: @_snapshot.LastCheckedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</p>
        }
      </div>
      @if (!_snapshot.IsDevMode)
      {
        <div class="hero__update-actions">
          @if (_snapshot.IsUpdateAvailable)
          {
            <button class="hero__button"
                    disabled="@(_isBusy || !_snapshot.CanCheckUpdates)"
                    @onclick="UpdateNowAsync">
              @(_isBusy ? "Procesando..." : "Actualizar ahora")
            </button>
            <button class="hero__button hero__button--secondary"
                    disabled="@(_isBusy || !_snapshot.CanCheckUpdates)"
                    @onclick="CheckForUpdatesAsync">
              Buscar de nuevo
            </button>
          }
          else
          {
            <button class="hero__button hero__button--secondary"
                    disabled="@(_isBusy || !_snapshot.CanCheckUpdates)"
                    @onclick="CheckForUpdatesAsync">
              @(_isBusy ? "Comprobando..." : "Buscar de nuevo")
            </button>
          }
        </div>
      }
    </section>

    <section class="hero__panel">
      <h2>Sesion</h2>
      <p>@_snapshot.StartupMessage</p>
      @if (!string.IsNullOrWhiteSpace(_progressMessage))
      {
        <p class="hero__progress">@_progressMessage</p>
      }
    </section>
  }
</div>

@code {
  private VelopackAppSnapshot? _snapshot;
  private bool _isBusy;
  private string _progressMessage = string.Empty;

  protected override async Task OnInitializedAsync()
  {
      _snapshot = UpdateService.GetSnapshot();
      if (_snapshot.CanCheckUpdates)
      {
          await CheckForUpdatesAsync();
      }
  }

  private async Task CheckForUpdatesAsync()
  {
      if (_snapshot is null || !_snapshot.CanCheckUpdates || _isBusy) {
          return;
      }

      _isBusy = true;
      _progressMessage = string.Empty;
      StateHasChanged();

      _snapshot = await UpdateService.CheckForUpdatesAsync(message =>
      {
          _progressMessage = message;
          InvokeAsync(StateHasChanged);
      });

      _progressMessage = string.Empty;
      _isBusy = false;
  }

  private async Task UpdateNowAsync()
  {
      if (_snapshot is null || !_snapshot.CanCheckUpdates || _isBusy) {
          return;
      }

      _isBusy = true;
      _progressMessage = string.Empty;
      StateHasChanged();

      var result = await UpdateService.DownloadAndApplyAsync(message =>
      {
          _progressMessage = message;
          InvokeAsync(StateHasChanged);
      });

      _snapshot = result.Snapshot;
      _progressMessage = result.ProgressMessage;
      _isBusy = false;
  }

  private string GetUpdateHeadline()
  {
      if (_snapshot is null) {
          return "Cargando";
      }

      if (_snapshot.IsDevMode) {
          return "Actualizaciones deshabilitadas";
      }

      if (_snapshot.IsUpdateAvailable) {
          return $"Actualizacion disponible: {_snapshot.AvailableVersion}";
      }

      return "Aplicacion al dia";
  }

  private string GetUpdatePanelClass()
  {
      if (_snapshot is null || _snapshot.IsDevMode) {
          return "hero__update--neutral";
      }

      return _snapshot.IsUpdateAvailable ? "hero__update--pending" : "hero__update--ok";
  }
}
