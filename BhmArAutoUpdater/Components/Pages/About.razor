@page "/about"
@inject BhmArAutoUpdater.Services.InstalledVersionCatalog VersionCatalog
@inject BhmArAutoUpdater.Services.GitHubReleaseCatalog GitHubReleaseCatalog
@inject BhmArAutoUpdater.Services.LauncherRelay LauncherRelay
@inject BhmArAutoUpdater.Services.ReleaseInstaller ReleaseInstaller

<div class="about-page">
    <div class="about-header">
        <h1>About</h1>
        @if (snapshot.IsDevelopmentMode)
        {
            <span class="dev-chip">DEV MODE</span>
        }
    </div>

    <p class="about-version">
        <span class="about-label">Version</span>
        <strong>@(snapshot.CurrentVersion?.DisplayName ?? "No identificada")</strong>
    </p>

    <div class="about-toolbar">
        <button class="btn btn-primary" @onclick="HandlePrimaryActionAsync" disabled="@PrimaryActionDisabled">
            @PrimaryActionLabel
        </button>
        <span class="about-status-line">
            <strong>@UpdateStatusText</strong>
        </span>
    </div>

    @if (!string.IsNullOrWhiteSpace(feedbackMessage))
    {
        <p class="about-feedback">@feedbackMessage</p>
    }

    @if (releaseLoadError is not null)
    {
        <p class="about-error"><strong>Error:</strong> @releaseLoadError</p>
    }
    else if (releases is null)
    {
        <p>Cargando releases...</p>
    }
    else if (releases.Count == 0)
    {
        <p>No se encontraron releases publicadas.</p>
    }
    else
    {
        <div class="about-table-shell @(snapshot.IsDevelopmentMode ? "about-table-shell-dev" : null)">
            <table class="table about-table">
                <thead>
                <tr>
                    <th>Publicacion</th>
                    <th>Version</th>
                    <th>Informacion</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var release in releases)
                {
                    <tr class="@GetRowClass(release)">
                        <td>@release.PublishedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="about-version-cell">@release.DisplayVersion</td>
                        <td class="about-info-cell">
                            <div class="about-chip-row">
                                @if (IsLatestRelease(release))
                                {
                                    <span class="about-chip about-chip-latest">Latest</span>
                                }
                                @if (!snapshot.IsDevelopmentMode && release.IsCurrentVersion)
                                {
                                    <span class="about-chip about-chip-running">Running</span>
                                }
                                @if (release.IsDownloaded)
                                {
                                    <span class="about-chip about-chip-downloaded">Downloaded</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private BhmArAutoUpdater.Services.VersionCatalogSnapshot snapshot = default!;
    private IReadOnlyList<BhmArAutoUpdater.Services.GitHubReleaseInfo>? releases;
    private string? releaseLoadError;
    private string? feedbackMessage;
    private DateTimeOffset? lastReleaseRefreshAt;
    private bool isBusy;
    private BhmArAutoUpdater.Services.GitHubReleaseInfo? latestRelease;

    private string PrimaryActionLabel
        => CanDownloadAndUpdate()
            ? "Descargar y actualizar"
            : "Comprobar actualizaciones";

    private bool PrimaryActionDisabled
        => isBusy || (snapshot.IsDevelopmentMode && releases is not null);

    private string UpdateStatusText
        => HasPendingUpdate()
            ? "Hay actualizaciones pendientes"
            : "No hay actualizaciones pendientes";

    protected override async Task OnInitializedAsync()
    {
        RefreshInstalledVersions();
        await RefreshReleasesAsync();
    }

    private void RefreshInstalledVersions()
    {
        snapshot = VersionCatalog.GetSnapshot();
    }

    private async Task RefreshReleasesAsync()
    {
        isBusy = true;
        releaseLoadError = null;
        feedbackMessage = null;
        StateHasChanged();

        try
        {
            RefreshInstalledVersions();
            releases = await GitHubReleaseCatalog.GetReleasesAsync();
            latestRelease = releases.FirstOrDefault();
            lastReleaseRefreshAt = DateTimeOffset.Now;
        }
        catch (Exception ex)
        {
            releaseLoadError = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task DownloadReleaseAsync(BhmArAutoUpdater.Services.GitHubReleaseInfo release)
    {
        isBusy = true;
        releaseLoadError = null;
        feedbackMessage = null;
        StateHasChanged();

        try
        {
            var result = await ReleaseInstaller.DownloadAndInstallAsync(release);
            feedbackMessage = result.Message;
            if (!result.Success)
            {
                return;
            }

            RefreshInstalledVersions();
            releases = await GitHubReleaseCatalog.GetReleasesAsync();
            latestRelease = releases.FirstOrDefault();
            lastReleaseRefreshAt = DateTimeOffset.Now;
        }
        catch (Exception ex)
        {
            releaseLoadError = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task HandlePrimaryActionAsync()
    {
        if (CanDownloadLatestRelease())
        {
            await DownloadReleaseAsync(latestRelease!);
            if (LauncherRelay.CanRestartThroughLauncher())
            {
                LauncherRelay.TryStartLauncher();
                Application.Current?.Quit();
            }
            return;
        }

        await RefreshReleasesAsync();
    }

    private string? GetRowClass(BhmArAutoUpdater.Services.GitHubReleaseInfo release)
    {
        if (snapshot.IsDevelopmentMode)
        {
            return "about-row-disabled";
        }

        return !release.HasPortableZip ? "about-row-muted" : null;
    }

    private bool IsLatestRelease(BhmArAutoUpdater.Services.GitHubReleaseInfo release)
        => latestRelease?.Version == release.Version;

    private bool HasPendingUpdate()
        => latestRelease is not null
           && latestRelease.HasPortableZip
           && !latestRelease.IsDownloaded;

    private bool CanDownloadLatestRelease()
        => !snapshot.IsDevelopmentMode
           && latestRelease is not null
           && latestRelease.HasPortableZip
           && !latestRelease.IsDownloaded;

    private bool CanDownloadAndUpdate()
        => CanDownloadLatestRelease() && LauncherRelay.CanRestartThroughLauncher();
}
