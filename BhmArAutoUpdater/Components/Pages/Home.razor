@page "/"
@inject BhmArAutoUpdater.Services.InstalledVersionCatalog VersionCatalog

<h1>BhmArAutoUpdater</h1>

<p>
    Version cargada:
    <strong>@(snapshot.CurrentVersion?.DisplayName ?? "No identificada")</strong>
</p>

@if (snapshot.IsDevelopmentMode)
{
    <p><strong>Modo:</strong> dev mode</p>
}

@if (otherVersions.Count == 0)
{
    <p>No hay otras versiones detectadas en la carpeta de la app.</p>
}
else
{
    <p>Otras versiones disponibles en el sistema de archivos:</p>
    <ul>
        @foreach (var version in otherVersions)
        {
            <li>@version.DisplayName</li>
        }
    </ul>
}

@code {
    private BhmArAutoUpdater.Services.VersionCatalogSnapshot snapshot = default!;
    private IReadOnlyList<BhmArAutoUpdater.Services.InstalledVersionInfo> otherVersions = [];

    protected override void OnInitialized()
    {
        snapshot = VersionCatalog.GetSnapshot();
        otherVersions = snapshot.AvailableVersions
            .Where(version => version.FolderName != snapshot.CurrentVersion?.FolderName)
            .ToArray();
    }
}
