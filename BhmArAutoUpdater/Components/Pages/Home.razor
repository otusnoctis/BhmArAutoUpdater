@page "/"
@inject BhmArAutoUpdater.Services.InstalledVersionCatalog VersionCatalog
@inject BhmArAutoUpdater.Services.GitHubReleaseCatalog GitHubReleaseCatalog
@inject BhmArAutoUpdater.Services.ReleaseInstaller ReleaseInstaller

<h1>BhmArAutoUpdater</h1>

<p>
    Version cargada:
    <strong>@(snapshot.CurrentVersion?.DisplayName ?? "No identificada")</strong>
</p>

@if (snapshot.IsDevelopmentMode)
{
    <p><strong>Modo:</strong> dev mode</p>
}

@if (otherVersions.Count == 0)
{
    <p>No hay otras versiones detectadas en la carpeta de la app.</p>
}
else
{
    <p>Otras versiones disponibles en el sistema de archivos:</p>
    <ul>
        @foreach (var version in otherVersions)
        {
            <li>@version.DisplayName</li>
        }
    </ul>
}

<hr />

<h2>Releases Del Repositorio</h2>

<p>
    <button class="btn btn-primary" @onclick="RefreshReleasesAsync" disabled="@isBusy">Actualizar releases</button>
</p>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <p><strong>Estado:</strong> @statusMessage</p>
}

@if (releaseLoadError is not null)
{
    <p><strong>Error:</strong> @releaseLoadError</p>
}
else if (releases is null)
{
    <p>Cargando releases...</p>
}
else if (releases.Count == 0)
{
    <p>No se encontraron releases publicadas.</p>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>Version</th>
            <th>Publicada</th>
            <th>Actual</th>
            <th>Descargada</th>
            <th>Zip disponible</th>
            <th>Accion</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var release in releases)
        {
            <tr>
                <td>@release.DisplayVersion</td>
                <td>@release.PublishedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@(release.IsCurrentVersion ? "Si" : "No")</td>
                <td>@(release.IsDownloaded ? "Si" : "No")</td>
                <td>@(release.HasPortableZip ? "Si" : "No")</td>
                <td>
                    @if (!release.HasPortableZip)
                    {
                        <span>No disponible</span>
                    }
                    else if (release.IsDownloaded)
                    {
                        <span>Ya descargada</span>
                    }
                    else
                    {
                        <button class="btn btn-secondary"
                                @onclick="() => DownloadReleaseAsync(release)"
                                disabled="@isBusy">
                            Descargar
                        </button>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private BhmArAutoUpdater.Services.VersionCatalogSnapshot snapshot = default!;
    private IReadOnlyList<BhmArAutoUpdater.Services.InstalledVersionInfo> otherVersions = [];
    private IReadOnlyList<BhmArAutoUpdater.Services.GitHubReleaseInfo>? releases;
    private string? releaseLoadError;
    private string? statusMessage;
    private bool isBusy;

    protected override async Task OnInitializedAsync()
    {
        RefreshInstalledVersions();
        await RefreshReleasesAsync();
    }

    private void RefreshInstalledVersions()
    {
        snapshot = VersionCatalog.GetSnapshot();
        otherVersions = snapshot.AvailableVersions
            .Where(version => version.FolderName != snapshot.CurrentVersion?.FolderName)
            .ToArray();
    }

    private async Task RefreshReleasesAsync()
    {
        isBusy = true;
        releaseLoadError = null;
        statusMessage = "Consultando releases en GitHub...";
        StateHasChanged();

        try
        {
            RefreshInstalledVersions();
            releases = await GitHubReleaseCatalog.GetReleasesAsync();
            statusMessage = $"Se han cargado {releases.Count} releases.";
        }
        catch (Exception ex)
        {
            releaseLoadError = ex.Message;
            statusMessage = null;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task DownloadReleaseAsync(BhmArAutoUpdater.Services.GitHubReleaseInfo release)
    {
        isBusy = true;
        releaseLoadError = null;
        statusMessage = $"Descargando {release.DisplayVersion}...";
        StateHasChanged();

        try
        {
            var result = await ReleaseInstaller.DownloadAndInstallAsync(release);
            statusMessage = result.Message;
            if (!result.Success)
            {
                return;
            }

            RefreshInstalledVersions();
            releases = await GitHubReleaseCatalog.GetReleasesAsync();
        }
        catch (Exception ex)
        {
            releaseLoadError = ex.Message;
            statusMessage = null;
        }
        finally
        {
            isBusy = false;
        }
    }
}
